# Переменные окружения PWA RocadaMed
# Скопировать в .env и заполнить

# URL API модуля rocada.visits на сервере Битрикс24
VITE_API_BASE_URL=https://office.rocadatech.ru/bitrix/modules/rocada.visits/lib/router.php

# URL портала Битрикс24
VITE_B24_BASE_URL=https://office.rocadatech.ru

# OAuth2 — заполнить после регистрации приложения в Б24
# Разработчикам → Локальное приложение → получить client_id
# Оставить пустым — будет доступна только форма логин/пароль
VITE_B24_CLIENT_ID=

# URL на который Б24 вернёт пользователя после входа (должен совпадать с Redirect URI в настройках приложения Б24)
VITE_B24_REDIRECT_URI=https://your-pwa-domain.ru/auth/callback
